# ============================================
# SwiftStock WMS Backend - Environment Variables
# Updated for pricelab_db shared database
# ============================================

# Database Configuration (Shared pricelab_db)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pricelab_db
DB_USER=swiftstock
DB_PASSWORD=your_secure_password_here

# Server Configuration
PORT=3006
NODE_ENV=production

# JWT Configuration
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_min64chars_use_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_min64chars_use_openssl_rand_hex_32
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# SSO Configuration
SSO_BASE_URL=https://apps.iwa.web.tr

# Internal Secret Sync (JWT_SECRET auto-propagation from Apps-SSO)
# SSO_INTERNAL_URL: internal URL of Apps-SSO (localhost — not the public domain)
# INTERNAL_API_KEY: must match the value in Apps-SSO's .env
# Generate with: openssl rand -hex 32
SSO_INTERNAL_URL=http://localhost:3005
INTERNAL_API_KEY=CHANGE_ME_match_apps_sso_value

# CORS Configuration
ALLOWED_ORIGINS=https://swiftstock.iwa.web.tr,https://www.iwa.web.tr

# Logging
LOG_LEVEL=info

# Optional: Redis Cache (if needed)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
